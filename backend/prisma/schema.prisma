generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MARKETING
  API
}

model User {
  id         Int      @id @default(autoincrement())
  fullName   String
  email      String   @unique
  password   String
  role       Role     @default(MARKETING)
  isActive   Boolean  @default(true)
  shops      Shop[]
  stockItems Stock[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Shop {
  id         Int      @id @default(autoincrement())
  name       String
  address    String
  gstNo      String?
  fssaiNo    String?
  ownerId    Int
  owner      User     @relation(fields: [ownerId], references: [id])
  stockItems Stock[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Stock {
  id          Int      @id @default(autoincrement())
  name        String
  sku         String?
  quantity    Int
  unit        String   @default("pcs")
  price       Float
  minStock    Int      @default(0)
  description String?
  shopId      Int
  shop        Shop     @relation(fields: [shopId], references: [id])
  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
